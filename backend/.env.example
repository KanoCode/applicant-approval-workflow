# Copy this file to .env and adjust as needed.

# Connection string Prisma uses. When running via docker-compose, "db" is
# the service name of the Postgres container (see ../docker-compose.yml).
# When running the backend locally against the dockerized DB, use
# localhost:5432 instead.
DATABASE_URL="postgresql://approval_user:approval_pass@db:5432/approval_db?schema=public"

FRONTEND_URL = "" #not needed for local development

JWT_SECRET="dev-only-secret-change-me"
JWT_EXPIRES_IN="8h"

PORT=4000
UPLOAD_DIR=uploads
MAX_UPLOAD_BYTES=5242880
NODE_ENV=development
